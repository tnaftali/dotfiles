# ═══════════════════════════════════════════════════════════════════════════════
# GIT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# ── User Identity ─────────────────────────────────────────────────────────────
[user]
	email = tobias.naftali@gmail.com
	name = Tobias Naftali

# ── Core Settings ─────────────────────────────────────────────────────────────
[init]
	defaultBranch = main

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

# ── Delta (diff pager) ───────────────────────────────────────────────────────
[delta]
	side-by-side = true
	line-numbers = true
	syntax-theme = Nord

# ── Git LFS ───────────────────────────────────────────────────────────────────
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

# ── Push & Pull ───────────────────────────────────────────────────────────────
[push]
	autoSetupRemote = true

# ── Merge & Conflicts ────────────────────────────────────────────────────────
[merge]
	conflictstyle = diff3

[rerere]
	enabled = true

# ── Branch & Checkout Settings ────────────────────────────────────────────────
[checkout]
	defaultRemote = origin
