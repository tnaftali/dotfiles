{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "attribution": {
    "commit": "Co-authored-by: Claude <noreply@anthropic.com>",
    "pr": "Co-authored-by: Claude <noreply@anthropic.com>"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit",
      "Write",
      "NotebookEdit",
      "Skill(research_codebase)",
      "Skill(format-run-tests-and-credo)",
      "WebFetch",
      "WebSearch",
      "mcp__*",
      "mcp__plugin_context-mode_context-mode__*"
    ],
    "deny": [
      "Bash(gh pr merge)",
      "Bash(gh repo delete)",
      "Bash(gh api)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push origin --delete*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(rm -rf *)",
      "Bash(*drop*)",
      "Bash(mix ecto.drop*)",
      "Bash(mix ecto.reset*)"
    ]
  },
  "model": "opus",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'afplay /System/Library/Sounds/Glass.aiff && osascript -e \"display notification \\\"Task Complete\\\" with title \\\"Claude Code (${CLAUDE_PROJECT_DIR##*/})\\\"\"; [ -n \"$TMUX\" ] && sess=$(tmux display -p -t \"$TMUX_PANE\" \"#{session_name}\") && tmux set -t \"$sess\" @claude_state done'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'env > /tmp/claude-hook-env.txt && afplay /System/Library/Sounds/Hero.aiff && osascript -e \"display notification \\\"Needs attention\\\" with title \\\"Claude Code (${PWD##*/})\\\"\"; [ -n \"$TMUX\" ] && sess=$(tmux display -p -t \"$TMUX_PANE\" \"#{session_name}\") && tmux set -t \"$sess\" @claude_state needs_input'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.agents/hooks/format-elixir.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"$CLAUDE_PROJECT_DIR/.agents/.claude/hooks/validate-elm.sh\" && bash \"$CLAUDE_PROJECT_DIR/.agents/.claude/hooks/validate-elm.sh\"",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/tobi/.claude/hooks/gsd-context-monitor.js\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/tobi/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/tobi/.claude/plugins/marketplaces/0.9.17/hooks/pretooluse.mjs"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"/opt/homebrew/bin/node\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "context-mode@claude-context-mode": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "medium",
  "plansDirectory": "./tmp/plans",
  "autoDreamEnabled": true,
  "preferredNotifChannel": "ghostty",
  "awaySummaryEnabled": false
}
